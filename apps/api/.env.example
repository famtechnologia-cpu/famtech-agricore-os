# ── Cloud API ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agricore:agricore@localhost:5432/agricore
SECRET_KEY=CHANGE_ME_TO_A_64_CHARACTER_RANDOM_STRING_BEFORE_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── MQTT (Cloud) ──────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://app.famtech.io"]

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_SIGNUP=true
ENABLE_DEMO_MODE=false
